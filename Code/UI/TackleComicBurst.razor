@using System
@using System.Collections.Generic
@using Sandbox
@using Sandbox.UI
@inherits PanelComponent

<root class="tackle-comic-burst tier-@TierClass @(UseLetterPopStagger ? "stagger-pop" : "") @(UseLetterImpactShake ? "letter-impact-shake" : "")">
	<div class="word-tilt" style="transform: rotate(@WordRotationStyle)">
		<div class="word-stack">
			<div class="word shadow" style="font-family: @FontFamily; transform: translate(@ShadowTransform)">
				@if ( Letters.Count > 0 )
				{
					@foreach ( var letter in Letters )
					{
						<div class="letter" style="@letter.ContainerStyle">@letter.Character</div>
					}
				}
				else
				{
					@DisplayText
				}
			</div>
			<div class="word fill" style="font-family: @FontFamily">
				@if ( Letters.Count > 0 )
				{
					@foreach ( var letter in Letters )
					{
						<div class="letter" style="@letter.ContainerStyle">@letter.Character</div>
					}
				}
				else
				{
					@DisplayText
				}
			</div>
		</div>
	</div>
</root>

@code
{
	private Sandbox.WorldPanel worldPanel;
	private TackleComicTextHud settings;
	private Vector3 driftOrigin;
	private float startTime;
	private bool configured;

	public IReadOnlyList<ComicLetterStyle> Letters { get; private set; } = Array.Empty<ComicLetterStyle>();
	public string DisplayText { get; private set; } = "";
	public string TierClass { get; private set; } = "sage";
	public string FontFamily { get; private set; } = "Poppins";
	public string ShadowTransform { get; private set; } = "10px, 12px";
	public string WordRotationStyle { get; private set; } = "0deg";
	public int LetterJitterSeed { get; private set; }
	public bool UseLetterPopStagger { get; private set; }
	public bool UseLetterImpactShake { get; private set; }

	public void ApplySpawnData( ComicBurstSpawnData data )
	{
		settings = data.Hud;
		DisplayText = data.Text ?? "";
		TierClass = TierToClass( data.Tier );
		FontFamily = data.Hud.ResolveFontFamily( data.Tier );
		LetterJitterSeed = data.LetterJitterSeed;
		UseLetterPopStagger = data.Hud.EnableLetterPopStagger;
		UseLetterImpactShake = data.Hud.EnableLetterImpactShake;
		Letters = data.LetterStyles ?? data.Hud.BuildLetterStyles( data.Text, data.Tier, data.LetterJitterSeed );
		TackleComicTextHud.ResolveShadowOffset( data.ShadowDirection, data.Hud.ShadowOffsetPixels, out var offsetX, out var offsetY );
		ShadowTransform = $"{offsetX:0}px, {offsetY:0}px";
		WordRotationStyle = $"{data.WordTiltDegrees:0.##}deg";
		driftOrigin = GameObject.WorldPosition;
		startTime = Time.Now;
		configured = true;
		RequestPanelRefresh();
	}

	protected override void OnStart()
	{
		worldPanel = Components.Get<Sandbox.WorldPanel>();
		ApplyRenderScale();
		RequestPanelRefresh();
	}

	protected override void OnTreeFirstBuilt()
	{
		base.OnTreeFirstBuilt();
		ApplyRenderScale();
		RequestPanelRefresh();
	}

	protected override void OnUpdate()
	{
		if ( !configured || !settings.IsValid() )
			return;

		var elapsed = Time.Now - startTime;
		if ( elapsed >= settings.LifetimeSeconds )
		{
			GameObject.Destroy();
			return;
		}

		GameObject.WorldPosition = driftOrigin + Vector3.Up * (settings.FloatUpSpeed * elapsed);
		UpdateOpacity( elapsed );
	}

	protected override int BuildHash()
	{
		var hash = new HashCode();
		hash.Add( DisplayText );
		hash.Add( TierClass );
		hash.Add( FontFamily );
		hash.Add( ShadowTransform );
		hash.Add( WordRotationStyle );
		hash.Add( LetterJitterSeed );
		hash.Add( UseLetterPopStagger );
		hash.Add( UseLetterImpactShake );

		foreach ( var letter in Letters )
		{
			hash.Add( letter.Character );
			hash.Add( letter.ContainerStyle );
		}

		return hash.ToHashCode();
	}

	void RequestPanelRefresh()
	{
		if ( !configured || Panel is null )
			return;

		StateHasChanged();
	}

	static string TierToClass( TackleComicTextHud.ComicFontTier tier )
	{
		return tier switch
		{
			TackleComicTextHud.ComicFontTier.Chaos => "chaos",
			TackleComicTextHud.ComicFontTier.Sans => "sans",
			_ => "sage"
		};
	}

	void ApplyRenderScale()
	{
		if ( !worldPanel.IsValid() || !settings.IsValid() )
			return;

		var scale = settings.RenderScale;
		if ( TierClass == "chaos" )
			scale *= settings.ChaosRenderScaleMultiplier;

		worldPanel.RenderScale = scale;
	}

	void UpdateOpacity( float elapsed )
	{
		if ( Panel is null )
			return;

		Panel.Style.Opacity = ComputeAlpha( elapsed, settings.LifetimeSeconds );
		Panel.Style.Dirty();
	}

	static float ComputeAlpha( float elapsed, float duration )
	{
		if ( duration <= 0.0001f )
			return 0f;

		var t = elapsed / duration;
		if ( t < 0.55f )
			return 1f;

		var fadeT = MathX.Clamp( (t - 0.55f ) / 0.45f, 0f, 1f );
		return 1f - fadeT;
	}
}
